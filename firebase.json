{
  "firestore": { "rules": "firestore.rules" },
  "hosting": {
    "public": ".",
    "ignore": ["firebase.json", "firestore.rules", ".firebaserc", ".firebase/**", ".git/**", ".gitignore", "firebase-debug.log", "README.md", "**/*.docx"],
    "cleanUrls": true,
    "headers": [
      {
        "source": "**/*.html",
        "headers": [{ "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }]
      },
      {
        "source": "/admin",
        "headers": [{ "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }]
      },
      {
        "source": "/admin.html",
        "headers": [{ "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }]
      },
      {
        "source": "**",
        "headers": [{ "key": "X-Content-Type-Options", "value": "nosniff" }]
      }
    ]
  }
}
